---
// src/components/Footer.astro
const currentYear = new Date().getFullYear();
---
<footer class="bg-white py-24 border-t border-brand-blue/10">
  <div class="max-w-7xl mx-auto px-6 md:px-12 flex flex-col items-center text-center reveal">
    
    <div class="mb-10 w-16 h-16 bg-brand-cream border border-brand-blue/10 flex items-center justify-center text-brand-blue shadow-sm">
      <i data-lucide="shield-check" class="w-8 h-8"></i>
    </div>
    <h3 class="text-3xl font-serif text-brand-text mb-8 font-bold tracking-tight">Compliance & Transparency</h3>
    
    <div class="space-y-3 mb-12">
      <p class="text-brand-text/90 font-medium text-lg">
        EA License: <span class="font-bold text-brand-blue">26C3351</span>
      </p>
      <p class="text-brand-text/90 font-medium text-lg">
        UEN: <span class="font-bold text-brand-blue">202605169C</span>
      </p>
      <div class="pt-4 text-brand-text/70 font-medium text-sm space-y-1">
        <p>228B Punggol Field #08-130, Singapore 822228</p>
        <p>Contact: +65 8152 2260</p>
      </div>
      <div class="pt-4 text-brand-text/70 font-medium text-sm space-y-1">
        <div class="flex items-center justify-center gap-2 text-brand-text/90 font-semibold mb-2">
          <i data-lucide="clock" class="w-4 h-4 text-brand-blue"></i>
          <span>Operating Hours</span>
        </div>
        <p>Monday: Closed</p>
        <p>Tuesday – Saturday: 10:00 AM – 7:30 PM</p>
        <p>Sunday: 10:00 AM – 2:00 PM</p>
        <p>Public Holidays: Closed</p>
      </div>

      <!-- Social Media Icons -->
      <div class="pt-6 flex items-center justify-center gap-6">
        <a href="https://facebook.com/alexisemployment" target="_blank" rel="noopener noreferrer" aria-label="Facebook"
           class="text-brand-text/40 hover:text-brand-blue transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M22 12c0-5.522-4.478-10-10-10S2 6.478 2 12c0 4.991 3.657 9.128 8.438 9.877v-6.987H7.898v-2.89h2.54V9.845c0-2.507 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.987C18.343 21.128 22 16.991 22 12z"/>
          </svg>
        </a>
        <a href="https://instagram.com/alexisemployment" target="_blank" rel="noopener noreferrer" aria-label="Instagram"
           class="text-brand-text/40 hover:text-brand-blue transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 1.366.062 2.633.336 3.608 1.311.975.975 1.249 2.242 1.311 3.608.058 1.266.07 1.646.07 4.85s-.012 3.584-.07 4.85c-.062 1.366-.336 2.633-1.311 3.608-.975.975-2.242 1.249-3.608 1.311-1.266.058-1.646.07-4.85.07s-3.584-.012-4.85-.07c-1.366-.062-2.633-.336-3.608-1.311-.975-.975-1.249-2.242-1.311-3.608C2.175 15.584 2.163 15.204 2.163 12s.012-3.584.07-4.85c.062-1.366.336-2.633 1.311-3.608.975-.975 2.242-1.249 3.608-1.311C8.416 2.175 8.796 2.163 12 2.163zm0-2.163C8.741 0 8.333.014 7.053.072 5.197.157 3.355.673 2.014 2.014.673 3.355.157 5.197.072 7.053.014 8.333 0 8.741 0 12c0 3.259.014 3.667.072 4.947.085 1.856.601 3.698 1.942 5.039 1.341 1.341 3.183 1.857 5.039 1.942C8.333 23.986 8.741 24 12 24c3.259 0 3.667-.014 4.947-.072 1.856-.085 3.698-.601 5.039-1.942 1.341-1.341 1.857-3.183 1.942-5.039.058-1.28.072-1.688.072-4.947 0-3.259-.014-3.667-.072-4.947-.085-1.856-.601-3.698-1.942-5.039C20.645.673 18.803.157 16.947.072 15.667.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zm0 10.162a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
          </svg>
        </a>
        <a href="https://tiktok.com/@alexis.employment" target="_blank" rel="noopener noreferrer" aria-label="TikTok"
           class="text-brand-text/40 hover:text-brand-blue transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.69a8.18 8.18 0 004.78 1.52V6.77a4.85 4.85 0 01-1.01-.08z"/>
          </svg>
        </a>
      </div>
    </div>

    <div class="mb-12">
      <div data-bid="169757" data-url="https://app.revu.cloud"></div>
      <script is:inline src="https://widget.reviewability.com/js/badgeAdv.min.js" async></script>
    </div>
    
    <p class="text-brand-text/60 text-xs font-medium mb-16 max-w-lg mx-auto leading-relaxed">
      We operate with total transparency and comply fully with the Singapore Employment Agencies Act and Ministry of Manpower regulations.
    </p>
    <div class="w-full h-px bg-brand-blue/10 mb-8"></div>
    <div class="flex flex-col md:flex-row justify-between items-center w-full text-[0.65rem] uppercase tracking-widest text-brand-text/50 font-bold">
      <p>&copy; {currentYear} Alexis Employment Pte Ltd. All rights reserved.</p>
      <div class="flex gap-6 mt-6 md:mt-0">
        <a href="#" class="hover:text-brand-blue transition-colors">Privacy Policy</a>
        <a href="#" class="hover:text-brand-blue transition-colors">Terms of Service</a>
      </div>
    </div>
  </div>
</footer>
