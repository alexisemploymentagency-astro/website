---
// src/components/DirectoryPreview.astro
import { supabase } from '../lib/supabase';

// 1. ENTERPRISE SECURITY: Check for the secure cookie on the server
const accessToken = Astro.cookies.get('sb-access-token')?.value;
let isAuthenticated = false;

if (accessToken) {
  const { data, error: authError } = await supabase.auth.getUser(accessToken);
  if (data?.user && !authError) {
    isAuthenticated = true;
  }
}

// 2. Fetch the top 3 newest helpers from Supabase
const { data: dbHelpers, error } = await supabase
  .from('helpers')
  .select('*')
  .order('created_at', { ascending: false })
  .limit(3);

if (error) {
  console.error("Supabase Error:", error.message);
}

// 3. Map the data perfectly for the UI
const displayHelpers = (dbHelpers || []).map(row => ({
  ...row,
  age: row.personal?.age || '-',
  experience: 'View Dossier', 
  marital_status: row.personal?.marital_status || '-',
  religion: row.personal?.religion || '-',
  skills: row.core_expertise || [] 
}));
---

<section id="browse" class="py-32 bg-brand-snow relative border-y border-brand-blue/5">
  <div class="max-w-7xl mx-auto px-6 md:px-12">
    
    <div class="flex flex-col md:flex-row md:items-end justify-between mb-16 reveal">
      <div class="max-w-2xl">
        <span class="text-[0.65rem] uppercase tracking-[0.3em] text-brand-blue font-bold mb-4 block"></span>
        <h2 class="text-4xl md:text-5xl font-serif text-brand-text tracking-tight mb-4">Curated Helpers</h2>
        <p class="text-brand-text/80 font-normal leading-relaxed">
          {isAuthenticated 
            ? "Welcome back. You are viewing unredacted previews of our latest available professionals." 
            : "Browse a preview of our carefully vetted selection of domestic helpers inclusive Myanmar, Indonesia, Philippines. Create a free client account to view full profiles."}
        </p>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-16">
      
      {displayHelpers.length > 0 ? (
        displayHelpers.map((helper, index) => (
          <div class={`bg-brand-cream border border-brand-blue/10 p-8 shadow-sm hover:shadow-premium-hover transition-all duration-500 reveal delay-${(index + 1) * 100} flex flex-col h-full group`}>
            
            <a href={`/profile/${helper.reference_code}`} class="block w-full h-48 mb-8 bg-brand-text/5 relative overflow-hidden border border-brand-blue/10 group-hover:border-brand-blue/30 transition-colors">
              <img src={helper.photo_url} alt="Candidate Profile" class={`profile-img w-full h-full object-cover object-top transition-all duration-700 ${isAuthenticated ? 'blur-0' : 'blur-lg scale-110 group-hover:scale-105'}`} />
              {!isAuthenticated && (
                <div class="absolute inset-0 flex items-center justify-center bg-brand-text/20 backdrop-blur-sm transition-opacity duration-500">
                  <i data-lucide="lock" class="w-8 h-8 text-white opacity-90"></i>
                </div>
              )}
            </a>

            <div class="flex items-start justify-between mb-8 pb-8 border-b border-brand-blue/10">
              <div>
                <a href={`/profile/${helper.reference_code}`} class="hover:text-brand-blue transition-colors">
                  <h3 class="text-xl font-serif text-brand-text mb-1 font-bold">
                    {helper.name}
                  </h3>
                </a>
                <p class="text-[0.65rem] text-brand-text/70 font-bold uppercase tracking-[0.2em]">Ref: {helper.reference_code}</p>
              </div>
              <div class="text-right">
                <span class="text-[0.65rem] uppercase tracking-[0.2em] text-brand-text/80 font-bold block">{helper.nationality}</span>
                <span class="inline-block mt-2 px-2 py-1 bg-brand-blue/10 text-brand-blue text-[0.60rem] font-bold uppercase tracking-widest">{helper.bio_type}</span>
              </div>
            </div>
            
            <div class="grid grid-cols-2 gap-y-6 gap-x-4 text-sm text-brand-text/90 mb-8 flex-grow">
              <div class="flex flex-col"><span class="text-[0.65rem] uppercase tracking-wider text-brand-text/60 font-bold mb-1">Age</span><span class="font-medium">{helper.age} Years</span></div>
              <div class="flex flex-col"><span class="text-[0.65rem] uppercase tracking-wider text-brand-text/60 font-bold mb-1">Languages</span><span class="font-medium">{helper.languages.join(', ')}</span></div>
              
              {isAuthenticated && (
                <>
                  <div class="flex flex-col"><span class="text-[0.65rem] uppercase tracking-wider text-brand-text/60 font-bold mb-1">Experience</span><span class="font-medium">{helper.experience}</span></div>
                  <div class="flex flex-col"><span class="text-[0.65rem] uppercase tracking-wider text-brand-text/60 font-bold mb-1">Status</span><span class="font-medium">{helper.marital_status}</span></div>
                  <div class="flex flex-col col-span-2"><span class="text-[0.65rem] uppercase tracking-wider text-brand-text/60 font-bold mb-1">Religion</span><span class="font-medium">{helper.religion}</span></div>
                </>
              )}
            </div>

            <div class="mb-10">
              <p class="text-[0.65rem] uppercase tracking-wider text-brand-text/60 font-bold mb-3">Core Expertise</p>
              <div class="flex flex-wrap gap-2">
                {helper.skills && Array.isArray(helper.skills) && helper.skills.map((skill: string) => (
                  <span class="px-3 py-1.5 bg-white text-brand-text text-xs font-medium border border-brand-blue/10 shadow-sm">{skill}</span>
                ))}
              </div>
            </div>

            {isAuthenticated ? (
              <a href={`/profile/${helper.reference_code}`} class="w-full flex py-4 text-center bg-brand-blue text-white text-xs uppercase tracking-[0.15em] font-bold hover:bg-brand-text transition-all duration-300 mt-auto items-center justify-center gap-3 shadow-premium">
                <i data-lucide="user" class="w-4 h-4"></i> View Full Dossier
              </a>
            ) : (
              <a href="/login" class="w-full flex py-4 text-center bg-white border border-brand-text/20 text-brand-text text-xs uppercase tracking-[0.15em] font-bold hover:border-brand-text transition-all duration-300 mt-auto items-center justify-center gap-3 shadow-sm">
                <i data-lucide="key" class="w-4 h-4"></i> Unlock Profile
              </a>
            )}

          </div>
        ))
      ) : (
        <div class="col-span-full py-12 text-center border border-brand-blue/10 bg-brand-cream shadow-sm flex flex-col items-center justify-center min-h-[300px]">
          <div class="w-16 h-16 bg-white rounded-full flex items-center justify-center mb-6 shadow-sm border border-brand-blue/5">
            <i data-lucide="database" class="w-6 h-6 text-brand-text/40"></i>
          </div>
          <h3 class="text-xl font-serif text-brand-text mb-2 font-bold">Connecting...</h3>
          <p class="text-brand-text/60 font-medium">Fetching secure preview data.</p>
        </div>
      )}

    </div>

    <div class="text-center reveal delay-300">
      <a href="/directory" class="inline-flex items-center justify-center px-10 py-5 bg-transparent border border-brand-text text-brand-text font-bold text-xs uppercase tracking-[0.15em] hover:bg-brand-text hover:text-white transition-colors duration-500 group">
        Browse All Helpers
        <i data-lucide="arrow-right" class="w-4 h-4 ml-3 group-hover:translate-x-1 transition-transform"></i>
      </a>
    </div>

  </div>
</section>