---
// src/pages/directory.astro
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { supabase } from '../lib/supabase'; // 1. Import your live connection!

// 2. Fetch the live data from Supabase!
const { data: dbHelpers, error } = await supabase
  .from('helpers')
  .select('*')
  .order('created_at', { ascending: false });

if (error) {
  console.error("Supabase Error:", error.message);
}

// 3. Map the Database JSON columns to perfectly match our beautiful UI
const displayHelpers = (dbHelpers || []).map(row => ({
  ...row,
  age: row.personal?.age || '-',
  experience: 'View Dossier', // Since we moved to a chronological timeline, we point them to the profile
  marital_status: row.personal?.marital_status || '-',
  religion: row.personal?.religion || '-',
  skills: row.core_expertise || [] // Map the DB column 'core_expertise' back to 'skills' for the UI
}));
---

<Layout title="Browse Available Helpers | Alexis Employment">
  <Navbar />
  
  <div class="bg-brand-cream border-b border-brand-blue/5 pt-40 md:pt-48 pb-16">
    <div class="max-w-7xl mx-auto px-6 md:px-12">
      <div class="reveal">
        <span class="text-[0.65rem] uppercase tracking-[0.3em] text-brand-blue font-bold mb-4 block">The Database</span>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-serif text-brand-text tracking-tight mb-6">Available Professionals</h1>
        <p id="hero-desc" class="text-brand-text/80 font-normal leading-relaxed max-w-2xl transition-opacity duration-300">
          Browse our strictly vetted roster. Create a free client account to view unredacted details and full candidate profiles.
        </p>
      </div>
    </div>
  </div>

  <main class="bg-white min-h-screen pt-12 pb-32">
    <div class="max-w-7xl mx-auto px-6 md:px-12">

      <div class="bg-white p-6 md:p-8 shadow-premium border border-brand-blue/20 mb-16 relative z-40 reveal delay-100">
        
        <div class="relative flex items-center px-4 py-3 border border-brand-blue/20 bg-brand-cream/30 mb-4">
          <i data-lucide="search" class="w-4 h-4 text-brand-text/60 mr-4"></i>
          <input type="text" id="filter-search" placeholder="Search by name or reference code..." class="w-full bg-transparent border-none outline-none text-brand-text placeholder:text-brand-text/60 text-sm font-medium focus:ring-0" />
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
          
          <div class="relative border border-brand-blue/20 bg-white">
            <select id="filter-nationality" class="w-full bg-transparent border-none outline-none text-brand-text text-xs font-bold uppercase tracking-wider appearance-none focus:ring-0 cursor-pointer py-4 pl-4 pr-10">
              <option value="all">All Nationalities</option>
              <option value="burmese">Burmese</option>
              <option value="indonesian">Indonesian</option>
              <option value="filipinos">Filipinos</option>
              <option value="mizoram">Mizoram</option>
            </select>
            <i data-lucide="chevron-down" class="w-4 h-4 text-brand-text/60 absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none"></i>
          </div>

          <div class="relative border border-brand-blue/20 bg-white">
            <select id="filter-biotype" class="w-full bg-transparent border-none outline-none text-brand-text text-xs font-bold uppercase tracking-wider appearance-none focus:ring-0 cursor-pointer py-4 pl-4 pr-10">
              <option value="all">All Bio Types</option>
              <option value="fresh">Fresh</option>
              <option value="ex-abroad">Ex-Abroad</option>
              <option value="transfer">Transfer</option>
              <option value="ex-singapore">Ex-Singapore</option>
            </select>
            <i data-lucide="chevron-down" class="w-4 h-4 text-brand-text/60 absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none"></i>
          </div>

          <div class="relative border border-brand-blue/20 bg-white">
            <select id="filter-language" class="w-full bg-transparent border-none outline-none text-brand-text text-xs font-bold uppercase tracking-wider appearance-none focus:ring-0 cursor-pointer py-4 pl-4 pr-10">
              <option value="all">All Languages</option>
              <option value="english">English</option>
              <option value="mandarin/chinese">Mandarin/Chinese</option>
              <option value="bahasa">Bahasa</option>
              <option value="tamil">Tamil</option>
              <option value="hindi">Hindi</option>
            </select>
            <i data-lucide="chevron-down" class="w-4 h-4 text-brand-text/60 absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none"></i>
          </div>

          <div class="relative border border-brand-blue/20 bg-white">
            <select id="filter-expertise" class="w-full bg-transparent border-none outline-none text-brand-text text-xs font-bold uppercase tracking-wider appearance-none focus:ring-0 cursor-pointer py-4 pl-4 pr-10">
              <option value="all">All Expertise</option>
              <option value="infant care">Infant Care</option>
              <option value="child care">Child Care</option>
              <option value="elderly care">Elderly Care</option>
              <option value="pets care">Pets Care</option>
              <option value="cooking/indonesian">Cooking/Indonesian</option>
              <option value="cooking/burmese">Cooking/Burmese</option>
            </select>
            <i data-lucide="chevron-down" class="w-4 h-4 text-brand-text/60 absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none"></i>
          </div>

        </div>

        <div class="flex items-center justify-between border-t border-brand-blue/10 pt-4">
          <span class="text-sm font-bold text-brand-blue tracking-wide">
            Showing <span id="resultCount">{displayHelpers.length}</span> Professionals
          </span>
          <button id="reset-filters" class="text-xs uppercase tracking-widest text-brand-text/60 hover:text-brand-red font-bold transition-colors">
            Reset Filters
          </button>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8" id="helperGrid">
        
        {displayHelpers.length > 0 ? (
          displayHelpers.map((helper, index) => (
            <div 
              class={`helper-card bg-brand-cream border border-brand-blue/10 p-8 shadow-sm hover:shadow-premium-hover transition-all duration-500 reveal delay-${(index % 3 + 1) * 100} flex flex-col h-full group`} 
              data-name={helper.name.toLowerCase()} 
              data-ref={helper.reference_code.toLowerCase()} 
              data-nationality={helper.nationality.toLowerCase()}
              data-biotype={helper.bio_type.toLowerCase()}
              data-languages={helper.languages.join(',').toLowerCase()}
              data-skills={helper.skills.join(',').toLowerCase()}
            >
              
              <a href={`/profile/${helper.reference_code}`} class="block w-full h-48 mb-8 bg-brand-text/5 relative overflow-hidden border border-brand-blue/10 group-hover:border-brand-blue/30 transition-colors">
                <img src={helper.photo_url} alt="Candidate Profile" class="profile-img w-full h-full object-cover object-top transition-all duration-700 blur-xl grayscale opacity-60 scale-110 group-hover:scale-105" />
                <div class="lock-overlay absolute inset-0 flex items-center justify-center bg-brand-text/20 backdrop-blur-sm transition-opacity duration-500">
                  <i data-lucide="lock" class="w-8 h-8 text-white opacity-80"></i>
                </div>
              </a>

              <div class="flex items-start justify-between mb-8 pb-8 border-b border-brand-blue/10">
                <div>
                  <a href={`/profile/${helper.reference_code}`} class="hover:text-brand-blue transition-colors">
                    <h3 class="auth-text text-xl font-serif text-brand-text mb-1 font-bold" data-real={helper.name}>{helper.alias} <span class="text-sm font-normal text-brand-text/50">(Restricted)</span></h3>
                  </a>
                  <p class="text-[0.65rem] text-brand-text/70 font-bold uppercase tracking-[0.2em]">Ref: {helper.reference_code}</p>
                </div>
                <div class="text-right">
                  <span class="text-[0.65rem] uppercase tracking-[0.2em] text-brand-text/80 font-bold block">{helper.nationality}</span>
                  <span class="inline-block mt-2 px-2 py-1 bg-brand-blue/10 text-brand-blue text-[0.60rem] font-bold uppercase tracking-widest">{helper.bio_type}</span>
                </div>
              </div>
              
              <div class="grid grid-cols-2 gap-y-6 gap-x-4 text-sm text-brand-text/90 mb-8 flex-grow">
                <div class="flex flex-col"><span class="text-[0.65rem] uppercase tracking-wider text-brand-text/60 font-bold mb-1">Age</span><span class="auth-text font-medium" data-real={`${helper.age} Years`}>Hidden</span></div>
                <div class="flex flex-col"><span class="text-[0.65rem] uppercase tracking-wider text-brand-text/60 font-bold mb-1">Experience</span><span class="auth-text font-medium" data-real={helper.experience}>Hidden</span></div>
                <div class="flex flex-col"><span class="text-[0.65rem] uppercase tracking-wider text-brand-text/60 font-bold mb-1">Status</span><span class="auth-text font-medium" data-real={helper.marital_status}>Hidden</span></div>
                <div class="flex flex-col"><span class="text-[0.65rem] uppercase tracking-wider text-brand-text/60 font-bold mb-1">Religion</span><span class="auth-text font-medium" data-real={helper.religion}>Hidden</span></div>
                <div class="flex flex-col col-span-2"><span class="text-[0.65rem] uppercase tracking-wider text-brand-text/60 font-bold mb-1">Languages</span><span class="auth-text font-medium" data-real={helper.languages.join(', ')}>Hidden</span></div>
              </div>

              <div class="mb-10">
                <p class="text-[0.65rem] uppercase tracking-wider text-brand-text/60 font-bold mb-3">Core Expertise</p>
                <div class="flex flex-wrap gap-2">
                  {helper.skills.map((skill: string) => (
                    <span class="px-3 py-1.5 bg-white text-brand-text text-xs font-medium border border-brand-blue/10 shadow-sm">{skill}</span>
                  ))}
                </div>
              </div>

              <a href={`/profile/${helper.reference_code}`} class="btn-unlocked hidden w-full py-4 text-center bg-brand-blue text-white text-xs uppercase tracking-[0.15em] font-bold hover:bg-brand-text transition-all duration-300 mt-auto items-center justify-center gap-3 shadow-premium">
                <i data-lucide="user" class="w-4 h-4"></i> View Full Dossier
              </a>
              <a href="/login" class="btn-locked w-full py-4 text-center bg-white border border-brand-text/20 text-brand-text text-xs uppercase tracking-[0.15em] font-bold hover:border-brand-text transition-all duration-300 mt-auto flex items-center justify-center gap-3 shadow-sm">
                <i data-lucide="key" class="w-4 h-4"></i> Unlock Profile
              </a>

            </div>
          ))
        ) : (
          <div class="col-span-full py-24 text-center border border-brand-blue/10 bg-brand-cream shadow-sm flex flex-col items-center justify-center">
            <div class="w-16 h-16 bg-white rounded-full flex items-center justify-center mb-6 shadow-sm border border-brand-blue/5">
              <i data-lucide="database" class="w-6 h-6 text-brand-text/40"></i>
            </div>
            <h3 class="text-xl font-serif text-brand-text mb-2 font-bold">Database Connecting</h3>
            <p class="text-brand-text/60 font-medium max-w-md mx-auto">
              No profiles found in Supabase. Run the SQL script to insert your candidate data.
            </p>
          </div>
        )}

      </div>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // 1. Auth Logic 
    const isAuthenticated = localStorage.getItem('alexis_dummy_auth') === 'true';

    if (isAuthenticated) {
      const heroDesc = document.getElementById('hero-desc');
      if (heroDesc) heroDesc.textContent = "Welcome back. You are viewing the full, unredacted database of available professionals.";

      document.querySelectorAll('.profile-img').forEach(img => {
        img.classList.remove('blur-xl', 'grayscale', 'opacity-60', 'scale-110');
        img.classList.add('blur-0', 'grayscale-0');
      });
      document.querySelectorAll('.lock-overlay').forEach(overlay => overlay.classList.add('opacity-0', 'pointer-events-none'));

      document.querySelectorAll('.auth-text').forEach(textNode => {
        const realData = textNode.getAttribute('data-real');
        if (realData) textNode.innerHTML = realData; // Use innerHTML to cleanly replace the span
      });

      document.querySelectorAll('.btn-locked').forEach(btn => btn.classList.add('hidden'));
      document.querySelectorAll('.btn-unlocked').forEach(btn => {
        btn.classList.remove('hidden');
        btn.classList.add('flex');
      });
    }

    // 2. Multi-Filter Logic
    const searchInput = document.getElementById('filter-search') as HTMLInputElement;
    const filterNat = document.getElementById('filter-nationality') as HTMLSelectElement;
    const filterBio = document.getElementById('filter-biotype') as HTMLSelectElement;
    const filterLang = document.getElementById('filter-language') as HTMLSelectElement;
    const filterExp = document.getElementById('filter-expertise') as HTMLSelectElement;
    const resetBtn = document.getElementById('reset-filters');
    
    const cards = document.querySelectorAll('.helper-card');
    const resultCount = document.getElementById('resultCount');

    function filterHelpers() {
      const searchVal = searchInput?.value.toLowerCase() || '';
      const natVal = filterNat?.value.toLowerCase() || 'all';
      const bioVal = filterBio?.value.toLowerCase() || 'all';
      const langVal = filterLang?.value.toLowerCase() || 'all';
      const expVal = filterExp?.value.toLowerCase() || 'all';
      
      let visibleCount = 0;

      cards.forEach((card) => {
        const c = card as HTMLElement;
        
        // Grab data embedded in the card
        const cardName = c.getAttribute('data-name') || '';
        const cardRef = c.getAttribute('data-ref') || '';
        const cardNat = c.getAttribute('data-nationality') || '';
        const cardBio = c.getAttribute('data-biotype') || '';
        const cardLangs = c.getAttribute('data-languages') || '';
        const cardSkills = c.getAttribute('data-skills') || '';

        // Check if card matches each filter
        const matchSearch = cardName.includes(searchVal) || cardRef.includes(searchVal);
        const matchNat = natVal === 'all' || cardNat === natVal;
        const matchBio = bioVal === 'all' || cardBio === bioVal;
        const matchLang = langVal === 'all' || cardLangs.includes(langVal);
        const matchExp = expVal === 'all' || cardSkills.includes(expVal);

        // ONLY show if it matches ALL active filters
        if (matchSearch && matchNat && matchBio && matchLang && matchExp) {
          c.style.display = 'flex';
          visibleCount++;
        } else {
          c.style.display = 'none';
        }
      });

      if (resultCount) resultCount.textContent = visibleCount.toString();
    }

    // Attach listeners to all inputs
    [searchInput, filterNat, filterBio, filterLang, filterExp].forEach(input => {
      if (input) input.addEventListener('input', filterHelpers);
    });

    // Reset Button Logic
    if (resetBtn) {
      resetBtn.addEventListener('click', () => {
        if(searchInput) searchInput.value = '';
        if(filterNat) filterNat.value = 'all';
        if(filterBio) filterBio.value = 'all';
        if(filterLang) filterLang.value = 'all';
        if(filterExp) filterExp.value = 'all';
        filterHelpers(); // Trigger reset
      });
    }
  });
</script>