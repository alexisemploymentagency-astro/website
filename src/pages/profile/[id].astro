---
// src/pages/profile/[id].astro
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { supabase } from '../../lib/supabase'; 

// 1. Fetch live from database
export async function getStaticPaths() {
  const { data: helpers, error } = await supabase.from('helpers').select('*');
  
  if (error) {
    console.error("Error fetching profiles for build:", error);
    return [];
  }

  return helpers.map((profile) => ({
    params: { id: profile.reference_code },
    props: { profile },
  }));
}

// 2. Grab the specific live profile data
const { profile } = Astro.props;
---

<Layout title={`Profile ${profile.reference_code} | Alexis Employment`}>
  <Navbar />
  
  <div class="bg-brand-cream border-b border-brand-blue/5 pt-40 pb-8 relative z-40">
    <div class="max-w-7xl mx-auto px-6 md:px-12">
      <a href="/directory" class="inline-flex items-center text-xs font-bold uppercase tracking-widest text-brand-text/60 hover:text-brand-blue transition-colors group">
        <i data-lucide="arrow-left" class="w-4 h-4 mr-2 group-hover:-translate-x-1 transition-transform"></i>
        Back to Directory
      </a>
    </div>
  </div>

  <main class="bg-white min-h-screen pt-12 pb-32">
    <div class="max-w-7xl mx-auto px-6 md:px-12">
      
      <div class="flex flex-col lg:flex-row gap-12 items-start">
        
        <div class="w-full lg:w-1/3 lg:sticky lg:top-32 reveal">
          <div class="bg-brand-cream border border-brand-blue/10 p-6 shadow-sm">
            
            <div class="w-full h-[400px] mb-6 bg-brand-text/5 relative overflow-hidden border border-brand-blue/10">
              <img 
                src={profile.photo_url} 
                alt="Candidate Profile" 
                class="profile-img w-full h-full object-cover object-top transition-all duration-700 blur-xl grayscale opacity-60 scale-110"
              />
              <div class="lock-overlay absolute inset-0 flex items-center justify-center bg-brand-text/20 backdrop-blur-sm transition-opacity duration-500">
                <i data-lucide="lock" class="w-10 h-10 text-white opacity-80"></i>
              </div>
            </div>

            <div class="text-center mb-6 pb-6 border-b border-brand-blue/10">
              <h1 class="auth-name text-3xl font-serif text-brand-text mb-2 font-bold" data-real={profile.name}>
                {profile.alias} <span class="text-lg font-normal text-brand-text/50">(Restricted)</span>
              </h1>
              <p class="text-xs text-brand-blue font-bold uppercase tracking-[0.2em]">Ref: {profile.reference_code}</p>
            </div>

            <div class="space-y-4 mb-8">
              <div class="flex justify-between items-center border-b border-brand-blue/5 pb-2">
                <span class="text-[0.65rem] uppercase tracking-wider text-brand-text/60 font-bold">Nationality</span>
                <span class="text-sm font-medium text-brand-text">{profile.nationality}</span>
              </div>
              <div class="flex justify-between items-center border-b border-brand-blue/5 pb-2">
                <span class="text-[0.65rem] uppercase tracking-wider text-brand-text/60 font-bold">Bio Type</span>
                <span class="text-sm font-medium text-brand-text">{profile.bio_type}</span>
              </div>
              <div class="flex justify-between items-center border-b border-brand-blue/5 pb-2">
                <span class="text-[0.65rem] uppercase tracking-wider text-brand-text/60 font-bold">Languages</span>
                <span class="text-sm font-medium text-brand-text text-right">{profile.languages.join(', ')}</span>
              </div>
            </div>

            <div class="mb-8">
              <p class="text-[0.65rem] uppercase tracking-wider text-brand-text/60 font-bold mb-3">Core Expertise</p>
              <div class="flex flex-wrap gap-2">
                {profile.core_expertise.map((skill: string) => (
                  <span class="px-3 py-1.5 bg-white text-brand-text text-[0.65rem] font-bold uppercase tracking-wider border border-brand-blue/10 shadow-sm">{skill}</span>
                ))}
              </div>
            </div>

            <a href="/login" class="btn-locked w-full py-4 text-center bg-white border border-brand-text/20 text-brand-text text-xs uppercase tracking-[0.15em] font-bold hover:border-brand-text transition-all duration-300 flex items-center justify-center gap-3 shadow-sm">
              <i data-lucide="key" class="w-4 h-4"></i> Unlock Full Dossier
            </a>
            <a href={`https://wa.me/6581522260?text=Hi%20Alexis%20Employment,%20I%20would%20like%20to%20inquire%20about%20Helper%20Ref:%20${profile.reference_code}`} target="_blank" rel="noopener noreferrer" class="btn-unlocked hidden w-full py-4 text-center bg-brand-blue text-white text-xs uppercase tracking-[0.15em] font-bold hover:bg-brand-text transition-all duration-300 items-center justify-center gap-3 shadow-premium">
              <i data-lucide="message-circle" class="w-4 h-4"></i> Inquire Now
            </a>
          </div>
        </div>

        <div class="w-full lg:w-2/3 reveal delay-200">
          
          <div id="locked-state" class="w-full bg-brand-cream/50 border border-brand-blue/10 p-12 text-center flex flex-col items-center justify-center min-h-[400px]">
            <div class="w-16 h-16 bg-white rounded-full flex items-center justify-center mb-6 shadow-sm border border-brand-blue/5">
              <i data-lucide="shield-alert" class="w-6 h-6 text-brand-text/40"></i>
            </div>
            <h3 class="text-2xl font-serif text-brand-text mb-3 font-bold">Dossier Restricted</h3>
            <p class="text-brand-text/70 font-medium max-w-md mx-auto mb-8 leading-relaxed">
              Detailed personal history, medical records, skills assessments, and chronological employment data are restricted to verified clients.
            </p>
            <a href="/login" class="inline-flex items-center justify-center px-8 py-4 bg-brand-blue text-white text-xs font-bold uppercase tracking-[0.2em] hover:bg-brand-text transition-colors duration-300 shadow-premium">
              Sign In to Reveal
            </a>
          </div>

          <div id="unlocked-state" class="hidden space-y-12">
            
            <section>
              <h2 class="text-xs uppercase tracking-[0.3em] text-brand-blue font-bold mb-6 border-b border-brand-blue/10 pb-4">Personal Details</h2>
              <div class="grid grid-cols-2 md:grid-cols-3 gap-6">
                <div><span class="block text-[0.65rem] text-brand-text/50 uppercase tracking-widest font-bold mb-1">Age / DOB</span><span class="text-sm font-medium text-brand-text">{profile.personal.age} ({profile.personal.dob})</span></div>
                <div><span class="block text-[0.65rem] text-brand-text/50 uppercase tracking-widest font-bold mb-1">Height / Weight</span><span class="text-sm font-medium text-brand-text">{profile.personal.height} / {profile.personal.weight}</span></div>
                <div><span class="block text-[0.65rem] text-brand-text/50 uppercase tracking-widest font-bold mb-1">Birthplace</span><span class="text-sm font-medium text-brand-text">{profile.personal.birthplace}</span></div>
                <div><span class="block text-[0.65rem] text-brand-text/50 uppercase tracking-widest font-bold mb-1">Religion</span><span class="text-sm font-medium text-brand-text">{profile.personal.religion}</span></div>
                <div><span class="block text-[0.65rem] text-brand-text/50 uppercase tracking-widest font-bold mb-1">Education</span><span class="text-sm font-medium text-brand-text">{profile.personal.education}</span></div>
                <div><span class="block text-[0.65rem] text-brand-text/50 uppercase tracking-widest font-bold mb-1">Siblings</span><span class="text-sm font-medium text-brand-text">{profile.personal.siblings}</span></div>
                <div><span class="block text-[0.65rem] text-brand-text/50 uppercase tracking-widest font-bold mb-1">Marital Status</span><span class="text-sm font-medium text-brand-text">{profile.personal.marital_status}</span></div>
                <div><span class="block text-[0.65rem] text-brand-text/50 uppercase tracking-widest font-bold mb-1">Children</span><span class="text-sm font-medium text-brand-text">{profile.personal.children}</span></div>
              </div>
            </section>

            <section>
              <h2 class="text-xs uppercase tracking-[0.3em] text-brand-blue font-bold mb-6 border-b border-brand-blue/10 pb-4">Medical & Dietary</h2>
              <div class="bg-brand-cream/30 border border-brand-blue/5 p-6 grid grid-cols-1 md:grid-cols-2 gap-4">
                <div class="flex items-center gap-3">
                  <i data-lucide="check-circle-2" class="w-4 h-4 text-green-600"></i>
                  <span class="text-sm font-medium text-brand-text">Allergies: {profile.medical.allergies}</span>
                </div>
                <div class="flex items-center gap-3">
                  <i data-lucide="check-circle-2" class="w-4 h-4 text-green-600"></i>
                  <span class="text-sm font-medium text-brand-text">Illnesses: {profile.medical.illnesses}</span>
                </div>
                <div class="flex items-center gap-3">
                  <i data-lucide="check-circle-2" class="w-4 h-4 text-green-600"></i>
                  <span class="text-sm font-medium text-brand-text">Disabilities: {profile.medical.disabilities}</span>
                </div>
                <div class="flex items-center gap-3">
                  <i data-lucide="check-circle-2" class="w-4 h-4 text-green-600"></i>
                  <span class="text-sm font-medium text-brand-text">Dietary: {profile.medical.dietary}</span>
                </div>
              </div>
            </section>

            <section>
              <h2 class="text-xs uppercase tracking-[0.3em] text-brand-blue font-bold mb-6 border-b border-brand-blue/10 pb-4">Skills Assessment</h2>
              <div class="space-y-4">
                {profile.skills_matrix.map((skill: any) => (
                  <div class="flex flex-col md:flex-row md:items-center justify-between p-4 bg-brand-cream border border-brand-blue/5">
                    <span class="text-sm font-bold text-brand-text mb-2 md:mb-0">{skill.skill}</span>
                    <div class="flex gap-1 text-yellow-500">
                      {Array.from({ length: 5 }).map((_, i) => (
                        <svg class={`w-4 h-4 ${i < skill.rating ? 'fill-current' : 'text-gray-300 fill-current'}`} viewBox="0 0 24 24">
                          <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                        </svg>
                      ))}
                    </div>
                  </div>
                ))}
              </div>
            </section>

            <section>
              <h2 class="text-xs uppercase tracking-[0.3em] text-brand-blue font-bold mb-6 border-b border-brand-blue/10 pb-4">Employment History</h2>
              <div class="relative border-l border-brand-blue/20 ml-3 space-y-8 pb-4">
                {profile.employment.map((job: any) => (
                  <div class="relative pl-8">
                    <div class="absolute w-3 h-3 bg-brand-blue rounded-full -left-[6.5px] top-1"></div>
                    <div class="mb-1 flex flex-wrap gap-2 items-center">
                      <span class="text-xs font-bold text-brand-text/60 uppercase tracking-widest">{job.from} - {job.to}</span>
                      <span class="px-2 py-0.5 bg-brand-cream text-brand-text text-[0.60rem] font-bold uppercase tracking-widest border border-brand-blue/10">{job.country}</span>
                    </div>
                    <h4 class="text-lg font-bold text-brand-text mb-3">{job.employer}</h4>
                    <ul class="space-y-2">
                      {job.duties.map((duty: string) => (
                        <li class="flex items-start text-sm text-brand-text/80">
                          <span class="mr-2 text-brand-blue mt-1">•</span>
                          <span class="leading-relaxed">{duty}</span>
                        </li>
                      ))}
                    </ul>
                  </div>
                ))}
              </div>
            </section>

          </div>
        </div>
      </div>

    </div>
  </main>

  <Footer />
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const isAuthenticated = localStorage.getItem('alexis_dummy_auth') === 'true';

    if (isAuthenticated) {
      document.querySelectorAll('.profile-img').forEach(img => {
        img.classList.remove('blur-xl', 'grayscale', 'opacity-60', 'scale-110');
        img.classList.add('blur-0', 'grayscale-0');
      });
      document.querySelectorAll('.lock-overlay').forEach(overlay => overlay.classList.add('opacity-0', 'pointer-events-none'));

      document.querySelectorAll('.auth-name').forEach(textNode => {
        const realData = textNode.getAttribute('data-real');
        if (realData) textNode.innerHTML = realData; 
      });

      document.querySelectorAll('.btn-locked').forEach(btn => btn.classList.add('hidden'));
      document.querySelectorAll('.btn-unlocked').forEach(btn => {
        btn.classList.remove('hidden');
        btn.classList.add('flex');
      });

      const lockedState = document.getElementById('locked-state');
      const unlockedState = document.getElementById('unlocked-state');
      
      if (lockedState) lockedState.classList.add('hidden');
      if (unlockedState) unlockedState.classList.remove('hidden');
    }
  });
</script>