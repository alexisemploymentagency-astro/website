---
// src/pages/login.astro
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Client Portal Login | Alexis Employment">
  <Navbar />
  
  <main class="bg-brand-cream min-h-screen pt-40 pb-32 flex flex-col items-center justify-center px-6">
    <div class="max-w-md w-full bg-white p-10 md:p-12 border border-brand-blue/10 shadow-premium reveal relative z-40">
      
      <div class="mb-10 text-center">
        <div class="w-12 h-12 bg-brand-cream mx-auto flex items-center justify-center text-brand-blue mb-6 border border-brand-blue/5">
          <i data-lucide="lock" class="w-5 h-5"></i>
        </div>
        <h1 class="text-3xl font-serif text-brand-text mb-2 font-bold tracking-tight">Client Portal</h1>
        <p class="text-sm text-brand-text/70">Sign in to view full, unredacted candidate dossiers.</p>
      </div>

      <div id="error-message" class="hidden w-full p-4 mb-6 bg-brand-red/10 border border-brand-red/20 text-brand-red text-xs font-bold text-center uppercase tracking-wider">
      </div>

      <form id="login-form" class="space-y-6">
        <div>
          <label for="email" class="block text-[0.65rem] font-bold uppercase tracking-[0.2em] text-brand-text/80 mb-2">Email Address</label>
          <input 
            type="email" 
            id="email" 
            required 
            class="w-full px-5 py-4 bg-brand-cream/50 border border-brand-blue/20 text-brand-text text-sm focus:bg-white focus:border-brand-blue focus:ring-0 outline-none transition-all"
            placeholder="you@example.com"
          />
        </div>
        
        <div>
          <label for="password" class="block text-[0.65rem] font-bold uppercase tracking-[0.2em] text-brand-text/80 mb-2">Password</label>
          <input 
            type="password" 
            id="password" 
            required 
            class="w-full px-5 py-4 bg-brand-cream/50 border border-brand-blue/20 text-brand-text text-sm focus:bg-white focus:border-brand-blue focus:ring-0 outline-none transition-all"
            placeholder="••••••••"
          />
        </div>

        <button 
          type="submit" 
          id="submit-btn"
          class="w-full py-4 mt-4 bg-brand-blue text-white text-xs font-bold uppercase tracking-[0.2em] hover:bg-brand-text transition-colors duration-300 shadow-premium flex justify-center items-center gap-2"
        >
          <span>Secure Sign In</span>
        </button>
      </form>

      <div class="mt-10 text-center border-t border-brand-blue/10 pt-8">
        <p class="text-xs text-brand-text/60 font-medium">
          Don't have an access account? <br/>
          <a href="/register" class="text-brand-blue font-bold uppercase tracking-widest hover:text-brand-text transition-colors mt-2 inline-block underline underline-offset-4 decoration-brand-blue/30 hover:decoration-brand-text">Apply for Access</a>
        </p>
      </div>

    </div>
  </main>

  <Footer />
</Layout>

<script>
  import { supabase } from '../lib/supabase';

  document.addEventListener('DOMContentLoaded', () => {
    const loginForm = document.getElementById('login-form');
    const submitBtn = document.getElementById('submit-btn');
    const errorMsg = document.getElementById('error-message');

    if (loginForm) {
      loginForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        const email = (document.getElementById('email') as HTMLInputElement).value;
        const password = (document.getElementById('password') as HTMLInputElement).value;

        if (submitBtn) {
          submitBtn.innerHTML = '<span class="animate-pulse">Authenticating...</span>';
          submitBtn.setAttribute('disabled', 'true');
        }
        if (errorMsg) errorMsg.classList.add('hidden');

        const { data, error } = await supabase.auth.signInWithPassword({
          email: email,
          password: password,
        });

        if (error) {
          if (submitBtn) {
            submitBtn.innerHTML = '<span>Secure Sign In</span>';
            submitBtn.removeAttribute('disabled');
          }
          if (errorMsg) {
            errorMsg.textContent = error.message; 
            errorMsg.classList.remove('hidden');
          }
          return;
        }

        if (data.session) {
          document.cookie = `sb-access-token=${data.session.access_token}; path=/; max-age=3600; SameSite=Lax`;
          localStorage.removeItem('alexis_dummy_auth'); 
        }
        
        // STEGG FIX: 200ms delay + Cache Buster
        setTimeout(() => {
          window.location.replace('/directory?action=login&t=' + Date.now());
        }, 200);
      });
    }
  });
</script>