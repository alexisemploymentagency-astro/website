---
// src/pages/register.astro
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Request Portal Access | Alexis Employment">
  <Navbar />
  
  <main class="bg-brand-cream min-h-screen pt-40 pb-32 flex flex-col items-center justify-center px-6">
    <div class="max-w-md w-full bg-white p-10 md:p-12 border border-brand-blue/10 shadow-premium reveal relative z-40">
      
      <div class="mb-10 text-center">
        <div class="w-12 h-12 bg-brand-cream mx-auto flex items-center justify-center text-brand-blue mb-6 border border-brand-blue/5">
          <i data-lucide="user-plus" class="w-5 h-5"></i>
        </div>
        <h1 class="text-3xl font-serif text-brand-text mb-2 font-bold tracking-tight">Request Access</h1>
        <p class="text-sm text-brand-text/70">Create a free client account to view full, unredacted candidate dossiers.</p>
      </div>

      <div id="error-message" class="hidden w-full p-4 mb-6 bg-brand-red/10 border border-brand-red/20 text-brand-red text-xs font-bold text-center uppercase tracking-wider">
      </div>

      <form id="register-form" class="space-y-5">
        
        <div>
          <label for="name" class="block text-[0.65rem] font-bold uppercase tracking-[0.2em] text-brand-text/80 mb-2">Full Name</label>
          <input 
            type="text" 
            id="name" 
            required 
            class="w-full px-5 py-4 bg-brand-cream/50 border border-brand-blue/20 text-brand-text text-sm focus:bg-white focus:border-brand-blue focus:ring-0 outline-none transition-all"
            placeholder="John Doe"
          />
        </div>

        <div>
          <label for="phone" class="block text-[0.65rem] font-bold uppercase tracking-[0.2em] text-brand-text/80 mb-2">WhatsApp Number</label>
          <input 
            type="tel" 
            id="phone" 
            required 
            class="w-full px-5 py-4 bg-brand-cream/50 border border-brand-blue/20 text-brand-text text-sm focus:bg-white focus:border-brand-blue focus:ring-0 outline-none transition-all"
            placeholder="+65 8123 4567"
          />
        </div>

        <div>
          <label for="email" class="block text-[0.65rem] font-bold uppercase tracking-[0.2em] text-brand-text/80 mb-2">Email Address</label>
          <input 
            type="email" 
            id="email" 
            required 
            class="w-full px-5 py-4 bg-brand-cream/50 border border-brand-blue/20 text-brand-text text-sm focus:bg-white focus:border-brand-blue focus:ring-0 outline-none transition-all"
            placeholder="you@example.com"
          />
        </div>
        
        <div>
          <label for="password" class="block text-[0.65rem] font-bold uppercase tracking-[0.2em] text-brand-text/80 mb-2">Create Password</label>
          <input 
            type="password" 
            id="password" 
            required 
            class="w-full px-5 py-4 bg-brand-cream/50 border border-brand-blue/20 text-brand-text text-sm focus:bg-white focus:border-brand-blue focus:ring-0 outline-none transition-all"
            placeholder="••••••••"
          />
          <p class="text-[0.60rem] text-brand-text/50 mt-2 uppercase tracking-widest">Minimum 6 characters</p>
        </div>

        <button 
          type="submit" 
          id="submit-btn"
          class="w-full py-4 mt-2 bg-brand-blue text-white text-xs font-bold uppercase tracking-[0.2em] hover:bg-brand-text transition-colors duration-300 shadow-premium flex justify-center items-center gap-2"
        >
          <span>Create Account</span>
        </button>
      </form>

      <div class="mt-8 text-center border-t border-brand-blue/10 pt-6">
        <p class="text-xs text-brand-text/60 font-medium">
          Already have an account? <br/>
          <a href="/login" class="text-brand-blue font-bold uppercase tracking-widest hover:text-brand-text transition-colors mt-2 inline-block underline underline-offset-4 decoration-brand-blue/30 hover:decoration-brand-text">Sign In Here</a>
        </p>
      </div>

    </div>
  </main>

  <Footer />
</Layout>

<script>
  // Import our secure Supabase connection
  import { supabase } from '../lib/supabase';

  document.addEventListener('DOMContentLoaded', () => {
    const registerForm = document.getElementById('register-form');
    const submitBtn = document.getElementById('submit-btn');
    const errorMsg = document.getElementById('error-message');

    if (registerForm) {
      registerForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        // Grab the values from the form
        const name = (document.getElementById('name') as HTMLInputElement).value;
        const phone = (document.getElementById('phone') as HTMLInputElement).value;
        const email = (document.getElementById('email') as HTMLInputElement).value;
        const password = (document.getElementById('password') as HTMLInputElement).value;

        // Update UI to Loading State
        if (submitBtn) {
          submitBtn.innerHTML = '<span class="animate-pulse">Connecting to Server...</span>';
          submitBtn.setAttribute('disabled', 'true');
        }
        if (errorMsg) errorMsg.classList.add('hidden');

        // FIRE TO SUPABASE
        const { data, error } = await supabase.auth.signUp({
          email: email,
          password: password,
          options: {
            data: {
              full_name: name,
              phone_number: phone
            }
          }
        });

        // HANDLE ERRORS (e.g., Email already exists, password too short)
        if (error) {
          if (submitBtn) {
            submitBtn.innerHTML = '<span>Create Account</span>';
            submitBtn.removeAttribute('disabled');
          }
          if (errorMsg) {
            errorMsg.textContent = error.message;
            errorMsg.classList.remove('hidden');
          }
          return;
        }

        // SUCCESS! 
        // We set the browser auth flag so the Directory knows to unblur the data
        localStorage.setItem('alexis_dummy_auth', 'true');
        
        // Redirect them straight to the unblurred directory
        window.location.href = '/directory';
      });
    }
  });
</script>